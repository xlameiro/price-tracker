# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================================
# Auth.js v5 (NextAuth)
# Generate a secret: openssl rand -base64 32
# ============================================================
AUTH_SECRET=your-auth-secret-here

# ============================================================
# OAuth Providers — uncomment the ones you use
# ============================================================

# Google OAuth — https://console.cloud.google.com/
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# GitHub OAuth
# AUTH_GITHUB_ID=your-github-client-id
# AUTH_GITHUB_SECRET=your-github-client-secret

# ============================================================
# Database — PostgreSQL (required)
# DIRECT_URL is used by Prisma CLI for migrations (bypasses PgBouncer).
# DATABASE_URL is used at runtime (can be a pooler URL, e.g. PgBouncer / Supabase pooler).
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/price_tracker
DIRECT_URL=postgresql://user:password@localhost:5432/price_tracker

# ============================================================
# Scraping — cron job secret (must match Vercel cron secret header)
# Generate: openssl rand -base64 32
# ============================================================
SCRAPE_CRON_SECRET=your-cron-secret-here
